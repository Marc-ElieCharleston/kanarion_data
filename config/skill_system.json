    "deficit": -50,
    "design_intent": "Force les choix de build, impossible de tout maxer"
  },

  "mana_cost_scaling": {
    "_comment": "Skill cost increases with level. Forces souffle investment to sustain high-level skills.",
    "default_mana_cost_per_level": 4,
    "formula": "mana_at_level = mana_cost + mana_cost_per_level * (level - 1)",
    "design_note": "Bread-and-butter skills: +3/lvl. Signatures: +6/lvl. Ultimates: +7-8/lvl."
  },

  "scaling": {
    "_comment": "Pure % stat scaling. Damage = stat * (scaling_percent + (level-1)*percent_per_level) / 100",
    "type": "pure_percent",
    "formula_scaling_percent": "percent_at_level = scaling_percent + (skill_level - 1) * percent_per_level",
    "formula_final_damage": "final = percent_at_level% * scaling_stat",
    "formula_mana": "mana_at_level = base_mana + (skill_level - 1) * mana_per_level",
    "formula_duration": "duration_at_level = base_duration + (skill_level - 1) * duration_per_level",
    "effect_chance": "fixed - geree par stats (effect_precision, tenacity, resist_debuff)",
    "cooldown": "fixed - vient de l'equipement/CDR",
    "design_note": "Physical skills: lower %, auto-attacks supplement. Magical skills: higher %, skills ARE the DPS. Cast time adds ~30%/sec bonus."
  },

  "stat_scaling": {
    "_comment": "scaling_stat = quelle stat le skill utilise pour le % scaling",
    "available_stats": ["atk", "mag", "def", "max_hp", "max_mp", "armor", "magic_resist"],
    "default_by_damage_type": {
      "physical": "atk",
      "magical": "mag",
      "none": null
    }
  },

